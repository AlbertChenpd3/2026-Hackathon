{
  "name": "Audio Mood Visualizer",
  "description": "Converts audio into dynamic visuals in real time to improve your mood.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "tabCapture", "activeTab", "scripting", "offscreen"],
  "background": {"service_worker": "scripts/background.js"}
}